pkgname=teamdesk
pkgver=1.4.6
pkgrel=0
epoch=
pkgdesc=""
arch=('x86_64')
url=""
license=('AGPL-3.0')
groups=()
depends=('gtk3' 'xdotool' 'libxcb' 'libxfixes' 'alsa-lib' 'libva' 'libappindicator-gtk3' 'pam' 'gst-plugins-base' 'gst-plugin-pipewire')
makedepends=()
checkdepends=()
optdepends=()
provides=()
conflicts=()
replaces=()
backup=()
options=()
install=pacman_install
changelog=
noextract=()
md5sums=() #generate with 'makepkg -g'

package() {
  if [[ ${FLUTTER} ]]; then
	  mkdir -p "${pkgdir}/usr/share/teamdesk" && cp -r ${HBB}/flutter/build/linux/x64/release/bundle/* -t "${pkgdir}/usr/share/teamdesk"
  fi
  mkdir -p "${pkgdir}/usr/bin"
  pushd ${pkgdir} && ln -s /usr/share/teamdesk/teamdesk usr/bin/teamdesk && popd
  install -Dm 644 $HBB/res/teamdesk.service -t "${pkgdir}/usr/share/teamdesk/files"
  install -Dm 644 $HBB/res/teamdesk.desktop -t "${pkgdir}/usr/share/teamdesk/files"
  install -Dm 644 $HBB/res/teamdesk-link.desktop -t "${pkgdir}/usr/share/teamdesk/files"
  install -Dm 644 $HBB/res/teamdesk.png "${pkgdir}/usr/share/icons/hicolor/256x256/apps/teamdesk.png"
  install -Dm 644 $HBB/res/teamdesk.svg "${pkgdir}/usr/share/icons/hicolor/scalable/apps/teamdesk.svg"
}
